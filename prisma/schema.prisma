// File: backend/prisma/schema.prisma (Final, Improved Version)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS - For type safety and data consistency
// -----------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  /// Core IDs
  id             String @id @default(cuid())
  supabaseAuthId String @unique

  /// Basic User Information
  username    String  @unique
  email       String? @unique
  displayName String?
  
  /// Profile Customization
  bio                    String?
  profileImageUrl        String?
  bannerImageUrl         String?
  profileBackgroundColor String? @default("#FFFFFF")

  /// Stripe & Payout Information
  stripeAccountId           String?  @unique
  stripeAccountCountry      String?
  stripeDefaultCurrency     String?
  stripeOnboardingComplete  Boolean  @default(false)
  payoutsInUsd              Boolean  @default(true)      // User's choice: receive payments in USD
  autoInstantPayoutsEnabled Boolean  @default(false)     // User's choice: false = Standard, true = Instant
  
  // Note: Optional Stripe-related fields like firstName, country, etc., were removed
  // as they are primarily handled by Stripe's onboarding and not needed in our direct schema.
  // This keeps the model cleaner.

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Relations
  links            Link[]
  paymentsReceived Payment[] @relation("RecipientPayments")

  /// Indexes
  @@index([supabaseAuthId])
  @@index([username])
}

model Link {
  /// Core Fields
  id     String @id @default(cuid())
  title  String
  url    String
  order  Int?
  clicks Int    @default(0)

  /// Relational Fields
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Indexes
  @@index([userId])
}

model Payment {
  /// Core IDs
  id                    String @id @default(cuid())
  stripePaymentIntentId String @unique

  /// Payment Details
  amount               Int
  currency             String
  status               PaymentStatus @default(PENDING) // Using the enum for type safety
  platformFee          Int?
  netAmountToRecipient Int?

  /// Payer Information
  payerName  String?
  payerEmail String?

  /// Relational Fields
  recipientUserId String
  recipient       User   @relation("RecipientPayments", fields: [recipientUserId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Added for tracking status changes

  /// Indexes
  @@index([recipientUserId])
}