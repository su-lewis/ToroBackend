generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(cuid())
  supabaseAuthId           String    @unique
  username                 String    @unique
  email                    String?   @unique
  displayName              String?
  bio                      String?
  profileImageUrl          String?
  stripeAccountId          String?   @unique
  stripeOnboardingComplete Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  bannerImageUrl           String?
  profileBackgroundColor   String?   @default("#FFFFFF")
  country                  String?
  dobDay                   Int?
  dobMonth                 Int?
  dobYear                  Int?
  firstName                String?
  lastName                 String?
  phone                    String?
  stripeAutoPayoutsEnabled Boolean   @default(false)
  stripeAccountCountry     String?
  stripeDefaultCurrency    String?
  
  payoutsInUsd             Boolean   @default(true)

  links                    Link[]
  paymentsReceived         Payment[] @relation("RecipientPayments")

  @@index([supabaseAuthId])
  @@index([username])
}

model Link {
  id        String   @id @default(cuid())
  title     String
  url       String
  userId    String
  order     Int?
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  id                    String   @id @default(cuid())
  stripePaymentIntentId String   @unique
  amount                Int
  currency              String
  status                String
  recipientUserId       String
  payerEmail            String?
  platformFee           Int?
  netAmountToRecipient  Int?
  createdAt             DateTime @default(now())
  payerName             String?
  recipient             User     @relation("RecipientPayments", fields: [recipientUserId], references: [id])
}
