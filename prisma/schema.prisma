generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS - For type safety and data consistency
// -----------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  DISPUTED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

/// A type defining what kind of content a block on a user's page represents.
enum PageBlockType {
  LINK
  WISHLIST
  HEADER
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  /// Core IDs
  id             String @id @default(cuid())
  supabaseAuthId String @unique

  /// Basic User Information
  username    String  @unique
  email       String? @unique
  displayName String?
  
  /// Profile Customization
  bio                    String?
  profileImageUrl        String?
  bannerImageUrl         String?
  profileBackgroundColor String? @default("#111827")

  /// Stripe & Payout Information
  stripeAccountId           String?  @unique
  stripeAccountCountry      String?
  stripeDefaultCurrency     String?
  stripeOnboardingComplete  Boolean  @default(false)
  payoutsInUsd              Boolean  @default(true)
  autoInstantPayoutsEnabled Boolean  @default(false)
  
  /// Platform-specific creator settings
  hasFeeRebateBonus         Boolean  @default(false)
  
  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Relations
  pageBlocks       PageBlock[] // A user has many page blocks. REPLACES `links`.
  paymentsReceived Payment[]   @relation("RecipientPayments")
  payouts          Payout[] 

  /// Indexes
  @@index([supabaseAuthId])
  @@index([username])
}

/// Represents a single, configurable block on a creator's public page.
model PageBlock {
  id    String  @id @default(cuid())
  /// The type of block this is (e.g., a simple link, a wishlist item, etc.).
  type  PageBlockType @default(LINK)
  /// The display order of the block on the page.
  order Int     @default(0)

  /// --- Fields for all block types ---
  title String?
  
  /// --- Fields specific to LINK type ---
  url   String?
  
  /// --- Fields specific to WISHLIST type ---
  priceCents   Int?
  quantityGoal Int?    // Nullable for "unlimited" items
  isUnlimited  Boolean @default(false)

  /// Relational Fields
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  /// A wishlist block can be funded by many payments.
  payments Payment[]

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Indexes
  @@index([userId])
}

model Payment {
  /// Core IDs
  id                    String @id @default(cuid())
  stripePaymentIntentId String @unique

  /// Payment Details
  amount               Int
  currency             String
  status               PaymentStatus @default(PENDING)
  platformFee          Int?
  netAmountToRecipient Int?

  /// Payer Information
  payerName  String?
  payerEmail String?

  /// Relational Fields
  recipientUserId String
  recipient       User   @relation("RecipientPayments", fields: [recipientUserId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  
  /// Relation to a specific item a fan might be purchasing.
  pageBlockId     String?
  pageBlock       PageBlock? @relation(fields: [pageBlockId], references: [id], onUpdate: SetNull, onDelete: SetNull)

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Indexes
  @@index([recipientUserId])
  @@index([pageBlockId])
}

model Payout {
  id              String       @id @default(cuid())
  stripePayoutId  String       @unique
  amount          Int
  currency        String
  status          PayoutStatus @default(PENDING)
  arrivalDate     DateTime?
  failureReason   String?

  /// Relational Fields
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Indexes
  @@index([userId])
}

model FailedPaymentAttempt {
  id              String   @id @default(cuid())
  stripePiId      String   @unique
  amount          Int
  currency        String
  recipientUserId String
  failureCode     String?
  failureMessage  String?

  createdAt       DateTime @default(now())

  /// Indexes
  @@index([recipientUserId])
}