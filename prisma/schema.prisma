generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS - For type safety and data consistency
// -----------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  DISPUTED
}

// --- NEW ---
enum PayoutStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  /// Core IDs
  id             String @id @default(cuid())
  supabaseAuthId String @unique

  /// Basic User Information
  username    String  @unique
  email       String? @unique
  displayName String?
  
  /// Profile Customization
  bio                    String?
  profileImageUrl        String?
  bannerImageUrl         String?
  profileBackgroundColor String? @default("#111827")

  /// Stripe & Payout Information
  stripeAccountId           String?  @unique
  stripeAccountCountry      String?
  stripeDefaultCurrency     String?
  stripeOnboardingComplete  Boolean  @default(false)
  payoutsInUsd              Boolean  @default(true)
  autoInstantPayoutsEnabled Boolean  @default(false)
  
  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Relations
  links            Link[]
  paymentsReceived Payment[] @relation("RecipientPayments")
  payouts          Payout[] 

  /// Indexes
  @@index([supabaseAuthId])
  @@index([username])
}

model Link {
  /// Core Fields
  id     String @id @default(cuid())
  title  String
  url    String
  order  Int?
  clicks Int    @default(0)

  /// Relational Fields
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Indexes
  @@index([userId])
}

model Payment {
  /// Core IDs
  id                    String @id @default(cuid())
  stripePaymentIntentId String @unique

  /// Payment Details
  amount               Int
  currency             String
  status               PaymentStatus @default(PENDING)
  platformFee          Int?
  netAmountToRecipient Int?

  /// Payer Information
  payerName  String?
  payerEmail String?

  /// Relational Fields
  recipientUserId String
  recipient       User   @relation("RecipientPayments", fields: [recipientUserId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Indexes
  @@index([recipientUserId])
}

model Payout {
  id              String       @id @default(cuid())
  stripePayoutId  String       @unique
  amount          Int
  currency        String
  status          PayoutStatus @default(PENDING)
  arrivalDate     DateTime?
  failureReason   String?

  /// Relational Fields
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Indexes
  @@index([userId])
}

model FailedPaymentAttempt {
  id              String   @id @default(cuid())
  stripePiId      String   @unique // Payment Intent ID
  amount          Int
  currency        String
  recipientUserId String
  failureCode     String?  // e.g., 'card_declined'
  failureMessage  String?

  createdAt       DateTime @default(now())

  // Note: We don't link this to a User model to keep it simple,
  // but you could add a relation if you wanted to analyze per-user failures.
  @@index([recipientUserId])
}